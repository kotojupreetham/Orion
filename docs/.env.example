# Copy to .env and put real values there. DO NOT commit .env with secrets.
# For a static site, use your build process to inject these values as globals or replace in JS.

ORION_FIREBASE_API_KEY=your-firebase-api-key
ORION_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
ORION_FIREBASE_DATABASE_URL=https://your-app-default-rtdb.region.firebasedatabase.app
ORION_FIREBASE_PROJECT_ID=your-app
ORION_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
ORION_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
ORION_FIREBASE_APP_ID=your-app-id
ORION_FIREBASE_MEASUREMENT_ID=your-measurement-id

ORION_AI_KEY=your-gemini-api-key
